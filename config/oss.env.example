# ============================================================
# 阿里云 OSS 凭证模板 —— 复制本文件为 oss.env 后填入真实值
# ============================================================
# 安装后执行：
#   cp config/oss.env.example config/oss.env
#   然后编辑 config/oss.env，填入下面 4 个必填项
#
# 脚本 generate_image.sh / upload_oss.py 会自动加载 config/oss.env。
# 安全：oss.env 含敏感凭证，勿提交 git、勿分享（已默认被 .gitignore 排除）。
# 强烈建议用 RAM 子账号 + 最小权限（仅该 Bucket 的 PutObject/GetObject）。
# ============================================================

export OSS_ACCESS_KEY_ID="填你的AccessKey_ID"
export OSS_ACCESS_KEY_SECRET="填你的AccessKey_Secret"
export OSS_BUCKET="填你的bucket名"
export OSS_ENDPOINT="如 oss-cn-hongkong.aliyuncs.com"
# ⚠️ OSS_DOMAIN 强烈建议留空（""）！
# 留空 -> 用 Bucket 默认域名（自带 HTTPS，官网图片正常显示，推荐）。
# 填自定义域名（如 oss-cms.jiasou.cn）-> 必须在阿里云控制台为该域名配好 SSL 证书，
#   否则 HTTPS 打不开、官网图片会裂（SSL 错误）。没配 SSL 证书就务必保持留空。
export OSS_DOMAIN=""
export OSS_PREFIX="elibot/articles"
# 设为 oss 后 generate_image.sh 默认上传 OSS（可被 --host 参数覆盖）；不用 OSS 则设为 none
export ELIBOT_IMAGE_HOST="oss"
